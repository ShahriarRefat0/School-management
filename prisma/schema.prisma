generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
model School {
  id               String   @id @default(cuid())
  schoolName       String
  slug             String   @unique
  schoolEmail      String   @unique
  phone            String?
  address          String?
  plan             String   @default("basic")
  duration         String   @default("12")
  
  // New Fields
  schoolCategory   String
  expectedStudents Int?     // Number হিসেবে সেভ করা ভালো
  registrationId   String   @unique
  facebookUrl      String?
  websiteUrl       String?
  language         String   @default("english")
  
  // Admin Info
  adminName        String
  adminEmail       String   @unique
  adminPassword    String   // এটি অবশ্যই হ্যাস (hash) করে সেভ করবেন
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


// Subscription Plans schema

model Plan {
  id        String   @id @default(cuid())
  name      String
  price     String
  duration  String
  icon      String?
  color     String?
  students  String
  teachers  String
  storage   String
  modules   String[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
