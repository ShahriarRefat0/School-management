generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//ROLE ENUM
enum Role {
  super_admin
  admin
  teacher
  student
  parent
  accountant
}

//user status ENUM
enum UserStatus {
  active
  blocked
}

//school data table

model School {
  id               String   @id @default(cuid())
  schoolName       String
  slug             String   @unique
  schoolEmail      String   @unique
  phone            String?
  address          String?
  plan             String   @default("basic")
  duration         String   @default("12")
  schoolCategory   String
  expectedStudents Int?    
  registrationId   String   @unique
  facebookUrl      String?
  websiteUrl       String?
  language         String   @default("english")
  adminName        String
  adminEmail       String   @unique
  // adminPassword    String                          //pass data table a rakha jaby na
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users         User[]         @relation("SchoolUsers")
  announcements Announcement[]
}

//announcement form principal data table

model Announcement {
  id              String    @id @default(cuid())
  title           String
  content         String    @db.Text
  
  // কাদের জন্য: "all", "teachers", "students", "staff"
  audience        String    @default("all") 
  
  // যদি Students সিলেক্ট করা হয়, তবে এখানে ক্লাসের নাম থাকবে (যেমন: "Class 10")
  // সবার জন্য হলে এটি null থাকবে
  targetClass     String?   
  
  // নোটিশের ধরণ: "academic", "holiday", "exam", "event", "emergency"
  category        String    @default("academic")
  
  // গুরুত্ব: "normal", "high", "urgent"
  priority        String    @default("normal")
  
  // ফাইল বা ইমেজ লিঙ্ক (ঐচ্ছিক)
  attachmentUrl   String?   
  
  publishDate     DateTime  @default(now())
  expiryDate      DateTime? // নোটিশটি কতদিন দেখাবে
  
  status          String    @default("published") // "published", "draft"
  
  // কোন স্কুল এই নোটিশ দিচ্ছে
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Author information
  authorId        String?
  authorName      String?

  createdAt       DateTime  @default(now())  
  updatedAt       DateTime  @updatedAt

  @@index([schoolId])
}

//students info data table
model Student {
  id               String   @id @default(uuid())
  registrationNo   String   @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  bloodGroup       String?
  religion         String?
  currentClass     String
  section          String
  rollNo           Int
  session          String
  admissionDate    DateTime @default(now())
  fatherName       String
  motherName       String
  guardianPhone    String
  emergencyContact String?
  email            String?  @unique
  presentAddress   String
  permanentAddress String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation("UserStudent", fields: [userId], references: [id])

  @@map("students")
}

//sub-plan data table
model Plan {
  id        String   @id @default(cuid())
  name      String
  price     String
  duration  String
  icon      String?
  color     String?
  students  String
  teachers  String
  storage   String
  modules   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//support ticket data table
model SupportTicket {
  id            String   @id @default(cuid())
  subject       String
  description   String
  priority      String   @default("low") 
  status        String   @default("open") // open, closed, pending
  schoolId      String?  // কোন স্কুল থেকে টিকিট আসছে
  userEmail     String   // কে টিকিট ক্রিয়েট করেছে
  attachmentUrl String?  // ইমেজ বা স্ক্রিনশট স্টোর করার জন্য এই ফিল্ডটি যোগ করা হলো
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//teacher data table
model Teacher {
  id               String   @id @default(uuid())
  teacherId        String   @unique
  firstName        String
  lastName         String
  email            String   @unique
  phone            String
  dateOfBirth      DateTime
  gender           String
  bloodGroup       String?
  religion         String?
  designation      String
  department       String
  qualification    String
  joiningDate      DateTime @default(now())
  salary           Float?
  presentAddress   String
  permanentAddress String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId String @unique
  user   User   @relation("UserTeacher", fields: [userId], references: [id])

  @@map("teachers")
}

//all users here

model User {
  id String @id @default(uuid())

  authUserId String @unique //supabase auth id
  schoolId   String

  role   Role
  status UserStatus @default(active)

  //relations 
  school School @relation("SchoolUsers", fields: [schoolId], references: [id])

  student Student? @relation("UserStudent")
  teacher Teacher? @relation("UserTeacher")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("User")
}
model testUser {
  id String @id @default(uuid())

  authUserId String @unique //supabase auth id
  schoolId   String

  role   Role
  status UserStatus @default(active)

  //relations 


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


}


