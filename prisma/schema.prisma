generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//ROLE ENUM
enum Role {
  super_admin
  admin
  teacher
  student
  parent
  accountant
}

//user status ENUM
enum UserStatus {
  active
  blocked
}

//school data table

model School {
  id               String   @id @default(cuid())
  schoolName       String
  slug             String   @unique
  schoolEmail      String   @unique
  phone            String?
  address          String?
  plan             String   @default("basic")
  duration         String   @default("12")
  schoolCategory   String
  expectedStudents Int?
  registrationId   String   @unique
  facebookUrl      String?
  websiteUrl       String?
  language         String   @default("english")
  adminName        String
  adminEmail       String   @unique
  // adminPassword    String                          //pass data table a rakha jaby na
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users         User[]         @relation("SchoolUsers")
  announcements Announcement[]
}

//announcement form principal data table

model Announcement {
  id            String    @id @default(cuid())
  title         String
  content       String
  audience      String    @default("all")
  targetClass   String?
  category      String    @default("academic")
  priority      String    @default("normal")
  attachmentUrl String?
  publishDate   DateTime  @default(now())
  expiryDate    DateTime?
  status        String    @default("published")
  schoolId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

//students info data table
model Student {
  id               String   @id @default(uuid())
  registrationNo   String   @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  bloodGroup       String?
  religion         String?
  currentClass     String
  section          String
  rollNo           Int
  session          String
  admissionDate    DateTime @default(now())
  fatherName       String
  motherName       String
  guardianPhone    String
  emergencyContact String?
  email            String?  @unique
  presentAddress   String
  permanentAddress String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation("UserStudent", fields: [userId], references: [id])

  @@map("students")
}

//sub-plan data table
model Plan {
  id        String   @id @default(cuid())
  name      String
  price     String
  duration  String
  icon      String?
  color     String?
  students  String
  teachers  String
  storage   String
  modules   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//support ticket data table
model SupportTicket {
  id            String   @id @default(cuid())
  subject       String
  description   String
  priority      String   @default("low")
  status        String   @default("open")
  schoolId      String?
  userEmail     String
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//teacher data table
model Teacher {
  id               String   @id @default(uuid())
  teacherId        String   @unique
  firstName        String
  lastName         String
  email            String   @unique
  phone            String
  dateOfBirth      DateTime
  gender           String
  bloodGroup       String?
  religion         String?
  designation      String
  department       String
  qualification    String
  joiningDate      DateTime @default(now())
  salary           Float?
  presentAddress   String
  permanentAddress String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId String @unique
  user   User   @relation("UserTeacher", fields: [userId], references: [id])

  @@map("teachers")
}

//all users here

model User {
  id String @id @default(uuid())

  authUserId String @unique //supabase auth id
  schoolId   String

  role   Role
  status UserStatus @default(active)

  //relations 
  school School @relation("SchoolUsers", fields: [schoolId], references: [id])

  student Student? @relation("UserStudent")
  teacher Teacher? @relation("UserTeacher")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("User")
}
