generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model School {
  id               String   @id @default(cuid())
  schoolName       String
  slug             String   @unique
  schoolEmail      String   @unique
  phone            String?
  address          String?
  plan             String   @default("basic")
  duration         String   @default("12")
  
  // New Fields
  schoolCategory   String
  expectedStudents Int?     // Number হিসেবে সেভ করা ভালো
  registrationId   String   @unique
  facebookUrl      String?
  websiteUrl       String?
  language         String   @default("english")
  
  // Admin Info
  adminName        String
  adminEmail       String   @unique
  adminPassword    String   // এটি অবশ্যই হ্যাস (hash) করে সেভ করবেন
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


// Subscription Plans schema

model Plan {
  id        String   @id @default(cuid())
  name      String
  price     String
  duration  String
  icon      String?
  color     String?
  students  String
  teachers  String
  storage   String
  modules   String[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// prisma/schema.prisma

model SupportTicket {
  id            String   @id @default(cuid())
  subject       String
  description   String
  priority      String   @default("low") // low, medium, high
  status        String   @default("open") // open, closed, pending
  schoolId      String?  // কোন স্কুল থেকে টিকিট আসছে
  userEmail     String   // কে টিকিট ক্রিয়েট করেছে
  attachmentUrl String?  // ইমেজ বা স্ক্রিনশট স্টোর করার জন্য এই ফিল্ডটি যোগ করা হলো
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
